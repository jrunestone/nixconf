{
  "workbench.colorTheme": "Min Tomorrow Dark",
  "workbench.startupEditor": "none",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "window.zoomLevel": 2.5,
  "dev.containers.dockerPath": "podman",
  "explorer.confirmDragAndDrop": false,
  "remote.restoreForwardedPorts": false,
  "remote.autoForwardPortsSource": "hybrid",
  "update.mode": "none",
  "extensions.ignoreRecommendations": true,
  "extensions.autoUpdate": false,
  "editor.codeLens": false,
  "editor.inlineSuggest.enabled": false,
  "editor.inlayHints.enabled": "off",
  "editor.smoothScrolling": true,
  "dotnet.formatting.organizeImportsOnFormat": true,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "telemetry.telemetryLevel": "off",
  "git.enableSmartCommit": true,
  "debug.onTaskErrors": "abort",
  "security.workspace.trust.enabled": false,

  "devcontainerDevCerts.userCertificates": [
    {
      "name": "rootCA",
      "pemCertPath": "/home/jr/.jr/certs/rootCA.pem"
    },
    {
      "name": "localhost",
      "pfxPath": "/home/jr/.jr/certs/localhost.pfx",
      "pfxPassword": "changeit",
      "trustInContainer": true
    }
  ],

  "devcontainerDevCerts.defaultKestrelCertificate": "localhost"
}
